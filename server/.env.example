# ============================================================
# Ever Nova Life — Braintree backend configuration
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env to git.
# ============================================================

# Where to talk to Braintree: "sandbox" (test money) or "production" (real money).
# Start with sandbox until everything works end-to-end.
BRAINTREE_ENV=sandbox

# From your Braintree Control Panel → Settings → API Keys.
# Use the SANDBOX credentials while BRAINTREE_ENV=sandbox,
# and the PRODUCTION credentials when you flip to BRAINTREE_ENV=production.
BRAINTREE_MERCHANT_ID=replace-with-your-merchant-id
BRAINTREE_PUBLIC_KEY=replace-with-your-public-key
BRAINTREE_PRIVATE_KEY=replace-with-your-private-key

# Currency for all charges (must be enabled on your merchant account).
CURRENCY=USD

# Port this API server listens on.
PORT=4242

# Comma-separated list of origins allowed to call this API.
# Use "*" only for local testing. In production list your real site origin,
# e.g. https://evernovalife.com
ALLOWED_ORIGINS=*

# ------------------------------------------------------------
# Accounts — sign in / sign up (email + password)
# ------------------------------------------------------------
# Secret used to sign login tokens (JWTs). Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If left blank the server uses a random secret that changes on every
# restart (fine for local dev, but all logins break when it restarts).
JWT_SECRET=

# How long a login stays valid (e.g. 7d, 30d, 12h). Optional; default 30d.
JWT_TTL=30d

# ------------------------------------------------------------
# Password-reset emails — Gmail SMTP
# ------------------------------------------------------------
# Your Gmail address, and a Google "App Password" (NOT your normal password).
# Create one: Google Account -> Security -> 2-Step Verification (must be ON)
# -> App passwords -> generate one for "Mail". Paste the 16-char code as SMTP_PASS.
SMTP_USER=
SMTP_PASS=
# Optional overrides (defaults are Gmail):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=Ever Nova Life <you@gmail.com>

# ------------------------------------------------------------
# Admin — view who has signed up
# ------------------------------------------------------------
# A long random secret. You'll enter it on admin.html to see the signup list.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_KEY=
# Where "new signup" notification emails are sent (usually your own inbox).
ADMIN_EMAIL=

# ------------------------------------------------------------
# Crypto payments — BTCPay Server (Bitcoin / Lightning)
# ------------------------------------------------------------
# Base URL of YOUR BTCPay instance (no trailing slash), e.g.
# https://pay.evernovalife.com
BTCPAY_URL=

# Greenfield API key: BTCPay -> Account -> Manage Account -> API Keys.
# Give it (at minimum) the "btcpay.store.cancreateinvoice" permission
# scoped to your store.
BTCPAY_API_KEY=

# Your store id: BTCPay -> Store Settings (also shown in the store URL).
BTCPAY_STORE_ID=

# Webhook secret shown when you create the webhook in BTCPay
# (Store -> Settings -> Webhooks). Point the webhook at:
#   https://<this-api>/api/crypto/webhook
# If left blank, incoming webhook calls are rejected (can't verify them).
BTCPAY_WEBHOOK_SECRET=

# Absolute URL of your storefront, used to send buyers back after paying.
# Optional — if blank, the server uses the request Origin. Set it when the
# API and site are on different hosts, e.g. https://evernovalife.com
SITE_URL=
